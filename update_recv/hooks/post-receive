#!/bin/bash

# -------------------------------
# Paths & ROLE
# -------------------------------
BARE_REPO="$(pwd)"
ROLE_FILE="$BARE_REPO/ROLE"
DEPS_DIR="$HOME/pasystem-deps"
SYSTEMD_USER_DIR="/home/$USER/.config/systemd/user"

if [[ ! -f "$ROLE_FILE" ]]; then
    echo "ERROR: ROLE file missing in bare repo!"
    exit 1
fi

ROLE=$(cat "$ROLE_FILE")

if [[ "$ROLE" != "server" && "$ROLE" != "client" ]]; then
    echo "ERROR: Invalid ROLE '$ROLE'! Must be 'server' or 'client'."
    exit 1
fi

# Parent dir (where we deploy)
PARENT_DIR="$(dirname "$BARE_REPO")"

# Temp dir for checkout
TMP_DIR="$(mktemp -d)"

cleanup() {
    rm -rf "$TMP_DIR"
}
trap cleanup EXIT

# -------------------------------
# Ensure there is at least one commit
# -------------------------------
if ! git rev-parse HEAD >/dev/null 2>&1; then
    echo "[post-receive] Bare repo empty, creating initial commit..."
    git --allow-empty commit -m "Initial commit" >/dev/null 2>&1
fi

# -------------------------------
# Checkout & Deploy
# -------------------------------
echo "[post-receive] Checking out 'main' branch to temp dir $TMP_DIR..."
git --work-tree="$TMP_DIR" checkout -f main

# Prepare rsync excludes from .gitignore
EXCLUDES=()
if [[ -f "$BARE_REPO/.gitignore" ]]; then
    echo "[post-receive] Using .gitignore from bare repo..."
    while IFS= read -r pattern || [[ -n "$pattern" ]]; do
        [[ -z "$pattern" || "$pattern" =~ ^[[:space:]]*# ]] && continue
        pattern="${pattern#"${pattern%%[![:space:]]*}"}"
        pattern="${pattern%"${pattern##*[![:space:]]}"}"
        [[ -n "$pattern" ]] && EXCLUDES+=("--exclude=$pattern")
    done < "$BARE_REPO/.gitignore"
fi

echo "[post-receive] Deploying files via rsync..."
rsync -a --delete "${EXCLUDES[@]}" \
    --exclude="$(basename "$BARE_REPO")" \
    --exclude=".git" \
    "$TMP_DIR/" "$PARENT_DIR/"

HOOK_SRC="$PARENT_DIR/post-receive"
HOOK_DST="$BARE_REPO/hooks/post-receive"

if [[ -f "$HOOK_SRC" ]]; then
    echo "[post-receive] Installing post-receive hook into bare repo..."

    mkdir -p "$BARE_REPO/hooks"
    cp "$HOOK_SRC" "$HOOK_DST"
    chmod +x "$HOOK_DST"
else
    echo "[post-receive] No external post-receive hook found, skipping"
fi



if [[ -f "$PARENT_DIR/python-runtime.zip" ]]; then
    echo "[post-receive] Installing python runtime..."
    mkdir -p "$DEPS_DIR/python-runtime"
    unzip -o "$PARENT_DIR/python-runtime.zip" -d "$DEPS_DIR/python-runtime"
	
	rm "$PARENT_DIR/python-runtime.zip"
else
    echo "[post-receive] Skipping python-runtime (zip not found)"
fi

if [[ -f "$PARENT_DIR/site-packages.zip" ]]; then
    

    mkdir -p "$DEPS_DIR/Mumble"

    # Create venv only if python runtime exists
    if [[ -x "$DEPS_DIR/python-runtime/bin/python" ]]; then
		echo "[post-receive] Installing site-packages..."
        "$DEPS_DIR/python-runtime/bin/python" -m venv "$DEPS_DIR/Mumble"

        SITE_PACKAGES_PATH="$DEPS_DIR/Mumble/lib/$(ls "$DEPS_DIR/Mumble/lib/" | head -1)/site-packages"
        mkdir -p "$SITE_PACKAGES_PATH"

        unzip -o "$PARENT_DIR/site-packages.zip" -d "$SITE_PACKAGES_PATH"
		
		rm "$PARENT_DIR/site-packages.zip"
    else


# -------------------------------
# Service Handling
# -------------------------------


if [[ "$ROLE" == "server" ]]; then
    echo "[post-receive] Deploying server services..."

    if [[ -f "$PARENT_DIR/systemd/mumble-office-server.service" ]]; then
        mkdir -p "$SYSTEMD_USER_DIR"
        cp "$PARENT_DIR/systemd/mumble-office-server.service" "$SYSTEMD_USER_DIR/"
        systemctl daemon-reload --user
        systemctl restart mumble-office-server --user
    else
        echo "[post-receive] Skipping mumble-office-server.service (not found)"
    fi

    if systemctl list-unit-files | grep -q "^mumble-server"; then
        sudo systemctl restart mumble-server || true
    fi

elif [[ "$ROLE" == "client" ]]; then
    echo "[post-receive] Deploying client services..."

    if [[ -f "$PARENT_DIR/systemd/mumble-headless-client.service" ]]; then
        mkdir -p "$SYSTEMD_USER_DIR"
        cp "$PARENT_DIR/systemd/mumble-headless-client.service" "$SYSTEMD_USER_DIR/"
        systemctl daemon-reload --user
        systemctl restart mumble-headless-client --user
    else
        echo "[post-receive] Skipping mumble-headless-client.service (not found)"
    fi
fi