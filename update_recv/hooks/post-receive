#!/bin/bash

# -------------------------------
# Paths & ROLE
# -------------------------------
BARE_REPO="$(pwd)"
ROLE_FILE="$BARE_REPO/ROLE"

if [[ ! -f "$ROLE_FILE" ]]; then
    echo "ERROR: ROLE file missing in bare repo!"
    exit 1
fi

ROLE=$(cat "$ROLE_FILE")

if [[ "$ROLE" != "server" && "$ROLE" != "client" ]]; then
    echo "ERROR: Invalid ROLE '$ROLE'! Must be 'server' or 'client'."
    exit 1
fi

# Parent dir (where we deploy)
PARENT_DIR="$(dirname "$BARE_REPO")"

# Temp dir for checkout
TMP_DIR="$(mktemp -d)"

cleanup() {
    rm -rf "$TMP_DIR"
}
trap cleanup EXIT

# -------------------------------
# Ensure there is at least one commit
# -------------------------------
if ! git rev-parse HEAD >/dev/null 2>&1; then
    echo "[post-receive] Bare repo empty, creating initial commit..."
    git --allow-empty commit -m "Initial commit" >/dev/null 2>&1
fi

# -------------------------------
# Checkout & Deploy
# -------------------------------
echo "[post-receive] Checking out 'main' branch to temp dir $TMP_DIR..."
git --work-tree="$TMP_DIR" checkout -f main

# Prepare rsync excludes from .gitignore
EXCLUDES=()
if [[ -f "$BARE_REPO/.gitignore" ]]; then
    echo "[post-receive] Using .gitignore from bare repo..."
    while IFS= read -r pattern || [[ -n "$pattern" ]]; do
        [[ -z "$pattern" || "$pattern" =~ ^[[:space:]]*# ]] && continue
        pattern="${pattern#"${pattern%%[![:space:]]*}"}"
        pattern="${pattern%"${pattern##*[![:space:]]}"}"
        [[ -n "$pattern" ]] && EXCLUDES+=("--exclude=$pattern")
    done < "$BARE_REPO/.gitignore"
fi

echo "[post-receive] Deploying files via rsync..."
rsync -a --delete "${EXCLUDES[@]}" \
    --exclude="$(basename "$BARE_REPO")" \
    --exclude=".git" \
    "$TMP_DIR/" "$PARENT_DIR/"

# -------------------------------
# Service Handling
# -------------------------------
if [[ "$ROLE" == "server" ]]; then
    echo "[post-receive] Deploying server services..."
    cp "$PARENT_DIR/systemd/mumble-office-server.service" /home/"$USER"/.config/systemd/user/ 2>/dev/null || true
    systemctl daemon-reload --user
    systemctl restart mumble-office-server --user
    sudo systemctl restart mumble-server || true
elif [[ "$ROLE" == "client" ]]; then
    echo "[post-receive] Deploying client services..."
    cp "$PARENT_DIR/systemd/mumble-headless-client.service" /home/"$USER"/.config/systemd/user/ 2>/dev/null || true
    systemctl daemon-reload --user
    systemctl restart mumble-headless-client --user
fi

echo "[post-receive] Updates successful ✅"
